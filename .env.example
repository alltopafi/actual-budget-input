# Server Config
PORT=3000
NODE_ENV=production
APP_PASSWORD=your-secure-access-password
# JWT_SECRET: If not provided, a random 32-byte secret will be generated on startup.
# Sessions will be invalidated when the server restarts if you leave this blank.
JWT_SECRET=your-random-jwt-signing-secret

# Actual Budget Config
ACTUAL_SERVER_URL=https://your-actual-budget-server.com
ACTUAL_SERVER_PASSWORD=your-actual-server-password
# The Sync ID can be found in Actual Budget under Settings -> Show Advanced Settings -> Budget ID (Sync ID).
ACTUAL_BUDGET_SYNC_ID=your-budget-sync-id-from-settings
ACTUAL_DATA_DIR=./data

# Optional Webhook Config
# If set, a POST request will be triggered in the background upon successful transaction creation.
# It receives rich JSON details including resolved account, payee, and category names.
TRANSACTION_WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# Optional API Key for external automation clients (e.g. Siri Shortcuts, curl, etc.)
# If configured, clients can POST transactions directly to /api/external/transactions
# by sending the header 'Authorization: Bearer <key>' or 'X-API-Key: <key>'.
API_KEY=your-secure-static-api-token-here
